{
  "name": "@memizy/multiplayer-sdk",
  "version": "0.3.0",
  "description": "TypeScript SDK for building Memizy multiplayer plugins with a declarative postMessage API.",
  "keywords": [
    "memizy",
    "multiplayer",
    "sdk",
    "postmessage",
    "typescript",
    "plugin"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/memizy/multiplayer-sdk.git"
  },
  "homepage": "https://github.com/memizy/multiplayer-sdk#readme",
  "bugs": {
    "url": "https://github.com/memizy/multiplayer-sdk/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/multiplayer-sdk.umd.cjs",
  "module": "./dist/multiplayer-sdk.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/multiplayer-sdk.js",
      "require": "./dist/multiplayer-sdk.umd.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc && vite build && tsx scripts/fix-types-entry.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "@memizy/oqse": "^0.1.4"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vite-plugin-dts": "^4.5.4"
  }
}
